{
  "expo": {
    "name": "Roamly",
    "slug": "Roamly",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "jsEngine": "jsc",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tanishgupta.roamly"
    },
    "android": {
      "package": "com.tanishgupta.roamly"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactNativeBridge": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e61a1eb4-5c63-433a-864d-63d93bcbf10e"
      }
    },
    "owner": "tanish1311"
  }
}